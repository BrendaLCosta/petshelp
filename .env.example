# =============================================
# PETSHELP - Variáveis de Ambiente
# =============================================

# =============================================
# BACKEND - Configuraçőes
# =============================================

# Ambiente
NODE_ENV=development
PORT=5000

# Banco de Dados
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=petshelp
DB_DIALECT=mysql

# JWT (Autenticaçăo)
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# E-mail (para envio de recibos e recuperaçăo)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=seu-email@gmail.com
EMAIL_PASS=sua-senha-app-gerada

# CORS (Cross-Origin Resource Sharing)
CORS_ORIGIN=http://localhost:3000

# =============================================
# FRONTEND - Configuraçőes
# =============================================

REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_ENV=development
REACT_APP_VERSION=1.0.0
REACT_APP_TOKEN_KEY=petshelp-token

# =============================================
# DOCKER (opcional - apenas se usar Docker)
# =============================================

MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=petshelp
MYSQL_USER=petshelp_user
MYSQL_PASSWORD=petshelp_pass